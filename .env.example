DATABASE_URL=postgres://postgres:postgres@localhost:5432/resend_router
PORT=3000
RUST_LOG=info,resend_router=debug,tower_http=info

# Resend webhook signing secret from the Resend dashboard/API.
RESEND_WEBHOOK_SECRET=whsec_replace_me

# Secret used to sign forwarded deliveries. Generate a long random value.
ROUTER_SIGNING_SECRET=replace-with-at-least-32-random-characters

# Railway-friendly JSON routing config. The default matcher routes by data.from domain.
DESTINATIONS_JSON=[{"name":"main-app","url":"https://example.com/webhooks/resend","from_domains":["example.com"]}]

# Optional tuning.
DELIVERY_WORKERS=2
DELIVERY_CLAIM_LIMIT=5
DELIVERY_TIMEOUT_SECS=20
RETRY_WINDOW_SECS=259200
WARN_AFTER_ATTEMPTS=10
RESEND_SIGNATURE_TOLERANCE_SECS=300
STALE_DELIVERY_LOCK_SECS=300
WORKER_DRAIN_TIMEOUT_SECS=30

# Railway: give workers time to finish/record in-flight deliveries on deploy shutdown.
RAILWAY_DEPLOYMENT_DRAINING_SECONDS=60
